# Function to extract numeric values from a string
def extract_numeric_values(x):
    x = str(x)
    x = x.replace(' hp', '').replace(' km/h', '').replace(' sec', '').replace(' Nm', '').replace('$', '').replace(',', '')
    x = x.replace(' - ', ' ')
    x = x.split()
    if len(x) > 1:
        return np.mean([float(i) for i in x if i.replace('.', '', 1).isdigit()])
    else:
        return x[0] if x[0].replace('.', '', 1).isdigit() else np.nan

# Apply the function to the numeric columns
